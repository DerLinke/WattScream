import sys
import argparse
import subprocess
import os
import shutil
import json
import time
from datetime import datetime

# --- INITIALISIERUNG ---
SCRIPTNAME = "wattScream"
VERSION = "0.1.0"
REPO_URL = "https://github.com/DerLinke/WattScream"

BASE_DIR = os.path.dirname(os.path.abspath(__file__))

def check_module(name):
    try:
        import importlib.util
        return importlib.util.find_spec(name) is not None
    except Exception:
        return False

def console_print(text):
    if check_module("rich"):
        from rich.console import Console
        Console().print(text)
    else:
        # Simple fallback parsing basic rich tags
        clean_text = text.replace("[bold green]", "").replace("[/bold green]", "") \
                         .replace("[green]", "").replace("[/green]", "") \
                         .replace("[yellow]", "").replace("[/yellow]", "") \
                         .replace("[bold red]", "").replace("[/bold red]", "") \
                         .replace("[red]", "").replace("[/red]", "") \
                         .replace("[bold white]", "").replace("[/bold white]", "") \
                         .replace("[dim]", "").replace("[/dim]", "") \
                         .replace("[blue]", "").replace("[/blue]", "") \
                         .replace("[blue underline]", "").replace("[/blue underline]", "") \
                         .replace("[/]", "")
        print(clean_text)

