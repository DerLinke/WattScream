    # Definition der Branding-Farben via Rich-Tags (Horizontaler Verlauf)
    C_L0 = "[rgb(255,0,0)]"
    C_L1 = "[rgb(245,0,10)]"
    C_L5 = "[rgb(208,0,47)]"
    C_L6 = "[rgb(198,0,57)]"
    C_L10 = "[rgb(161,0,94)]"
    C_L11 = "[rgb(151,0,104)]"

    C_R17 = "[rgb(96,0,159)]"
    C_R18 = "[rgb(86,0,169)]"
    C_R19 = "[rgb(76,0,179)]"
    C_R20 = "[rgb(66,0,189)]"
    C_R21 = "[rgb(56,0,199)]"
    C_R22 = "[rgb(47,0,208)]"
    C_R26 = "[rgb(9,0,246)]"
    C_R27 = "[rgb(0,0,255)]"

    console_print(f"          {C_L10}█{C_L11}█[/]     {C_R17}█{C_R18}█{C_R19}█{C_R20}█{C_R21}█[/]")
    console_print(f"     {C_L5}█{C_L6}█[/]                    {C_R26}█{C_R27}█[/]")
    console_print(f"{C_L0}█{C_L1}█[/]                {C_R18}█{C_R19}█{C_R20}█{C_R21}█{C_R22}█[/] [bold white]{SCRIPTNAME} v{VERSION}[/bold white]")
    console_print(f"     {C_L5}█{C_L6}█[/]                    {C_R26}█{C_R27}█[/]")
